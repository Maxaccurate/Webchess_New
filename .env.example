# WebChess 环境变量配置

# 应用信息
VITE_APP_NAME=WebChess
VITE_APP_DESCRIPTION=Web-based chess game with AI对战 and multiplayer
VITE_APP_VERSION=1.0.0

# 多人对战服务器配置
# 开发环境
VITE_WS_URL_DEV=ws://localhost:3000
VITE_API_URL_DEV=http://localhost:3000

# 生产环境（部署后更新）
# VITE_WS_URL_PROD=wss://your-railway-server.up.railway.app
# VITE_API_URL_PROD=https://your-railway-server.up.railway.app

# 功能开关
VITE_ENABLE_AI=true
VITE_ENABLE_MULTIPLAYER=true
VITE_ENABLE_TIMER=true

# 默认设置
VITE_DEFAULT_AI_SCORE=1000
VITE_DEFAULT_TIMER_MINUTES=10
VITE_DEFAULT_TIMER_SECONDS=5